# 用于获取对冲基金所需的金融数据
# 从 https://financialdatasets.ai/ 获取 Financial Datasets API 密钥
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# 用于运行 OpenAI 托管的大语言模型（GPT 5 等）
# 从 https://platform.openai.com/ 获取 OpenAI API 密钥
OPENAI_API_KEY=your-openai-api-key

# 用于运行 Anthropic 托管的大语言模型（claude-4-sonnet、claude-4.1-opus 等）
# 从 https://anthropic.com/ 获取 Anthropic API 密钥
ANTHROPIC_API_KEY=your-anthropic-api-key

# 用于运行 DeepSeek 托管的大语言模型（deepseek-chat、deepseek-reasoner 等）
# 从 https://deepseek.com/ 获取 DeepSeek API 密钥
DEEPSEEK_API_KEY=your-deepseek-api-key

# 用于运行 Groq 托管的大语言模型（deepseek、llama3 等）
# 从 https://groq.com/ 获取 Groq API 密钥
GROQ_API_KEY=your-groq-api-key

# 用于运行 Gemini 托管的大语言模型（gemini-2.5-flash、gemini-2.5-pro）
# 从 https://ai.dev/ 获取 Google API 密钥
GOOGLE_API_KEY=your-google-api-key

# 用于运行 xAI 托管的大语言模型（Grok 4 等）
XAI_API_KEY=your-xai-api-key

# 用于运行 Moonshot / Kimi 托管的大语言模型（kimi-k2、kimi-latest、moonshot-v1-*）
# 从 https://platform.moonshot.ai/ 获取 Moonshot API 密钥
# 中国大陆用户请设置 MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=your-moonshot-api-key

# 用于运行 GigaChat 大语言模型
GIGACHAT_API_KEY=your-gigachat-api-key

# 用于运行 OpenRouter 托管的大语言模型
OPENROUTER_API_KEY=your-openrouter-api-key

# 用于运行 Microsoft Azure OpenAI 托管的大语言模型（gpt-4o、gpt-4o-mini 等）
# 从 https://oai.azure.com/ 获取 Azure OpenAI API 配置
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment-name
